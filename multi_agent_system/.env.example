# Default model to use if not specified in YAML
# Examples: groq/llama-3.1-70b-versatile, openai/gpt-4o-mini, ollama/llama3.2
DEFAULT_MODEL=groq/llama3-8b-8192

# --- PROVIDER KEYS ---

# Groq
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (Optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
